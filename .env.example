# לקוח (Vite) — העתק ל־.env.local
VITE_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
# שורת משנה ליד הלוגו בדף הלקוח (ברירת מחדל: רכישת כרטיסים)
# VITE_PUBLIC_VENUE_TAGLINE=ברכת הסולטן
#
# תשלום ב-Bit (בנתיים — העברה ידנית, ללא API בנק)
# VITE_BIT_PHONE=0501234567
# VITE_BIT_PAYEE_NAME=מסיבת סוף הקיץ
# אופציונלי: מזהה אירוע ב-Convex לקישור רכישות (לוח → events). אם ריק, נלקח האירוע הפעיל הראשון.
# VITE_CHECKOUT_EVENT_ID=jd7abc123...

# בשרת Convex (Settings → Environment Variables) — או ב-CLI (לא בקובץ Vite!):
# SITE_URL, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
#
# SITE_URL: כבר הוגדר ב-CLI: dev= http://localhost:5173, prod= דומיין Netlify. לשנות: npx convex env set [ --prod ] SITE_URL "https://..."
#
# STRIPE: העתק מ- https://dashboard.stripe.com/apikeys (מצב Test)
#   npm run convex:stripe-apply -- "sk_test_xxxxxxxx"    (יוצר ב-dev וב-prod)
# או: npx convex env set STRIPE_SECRET_KEY "sk_test_..."   ו- npx convex env set --prod STRIPE_SECRET_KEY "sk_test_..."
# STRIPE_WEBHOOK_SECRET=whsec_...   (אחרי יצירת Webhook ב-Stripe, מסך Webhooks)
#
# Webhook URL ב-Stripe (אותו דומיין כמו ב-Convex):
#   https://<convex_deployment>.convex.site/stripe-webhook
#   (רואים ב-Convex: Settings → URL & Deploy Key → בחר HTTP Actions URL)
